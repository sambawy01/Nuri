# AI Provider: "claude" or "ollama" (default: claude)
AI_PROVIDER=claude

# Claude API (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your-key-here

# Ollama (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database
DATABASE_URL=postgresql://localhost:5432/nuri

# Server
PORT=3001

# ElevenLabs TTS (optional — enables premium voice via backend proxy)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Optional voice ID — defaults to l4Coq6695JDX9xtLqXDE
ELEVENLABS_VOICE_ID=l4Coq6695JDX9xtLqXDE
# Optional model ID — defaults to eleven_multilingual_v2
ELEVENLABS_MODEL=eleven_multilingual_v2
