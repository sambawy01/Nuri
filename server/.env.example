# AI Provider: "claude" or "ollama" (default: claude)
AI_PROVIDER=claude

# Claude API (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your-key-here

# Ollama (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database
DATABASE_URL=postgresql://localhost:5432/nuri

# Server
PORT=3001
